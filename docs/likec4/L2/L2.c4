specification {
  element actor {
    style {
      shape person
    }
  }
  element externalSystem {
    style {
      color secondary
    }
  }
  element system
  element container
  element optionalContainer {
    style {
      color amber
    }
  }
  element crossCutting {
    style {
      color sky
    }
  }
  element facet {
    style {
      color indigo
    }
  }
}

model {
  agent = actor 'External AI Agent' 'Normalizes raw inputs; relays system responses to humans'
  llm = externalSystem 'Cloud / Local LLM' 'Deployer-configured models — hosted (Anthropic / OpenAI / etc.) or local (Ollama / vLLM / etc.) — accessed via the deployer''s chosen gateway tool (LiteLLM / OpenRouter / Portkey / direct).'
  storage = externalSystem 'Snapshot Backing Store' 'Git working tree / database snapshots / content-addressed manifest (implementation choice)'

  aala = system 'aala' 'Knowledge Compiler — atoms as System of Record, prose as a per-container projection facet; external agents compose answers over the read surfaces' {
    orchestration = container 'Orchestration' 'Lifecycle coordinator. Snapshot lifecycle, tree registry, capability routing, external API surface.'
    ingestion = container 'Ingestion' 'Raw inputs in. Normalize, filter, persist raw fragments. Tree-agnostic.'
    atoms = container 'Atoms' 'Canonical SoR. Typed grammar (entity / relation / classification / predicate / predicate_kind). Schema, extraction, conflict classification, status transitions, three-channel cascade, classification + predicate resolution, alias graph, entailment. Emits ordered delta stream. Hosts the Projection facet over its claims.'
    projection = facet 'Projection (facet)' 'Read facet, not a container. Each contentful container renders its own state to prose + a navigable index (list / read / read_index / changes_since). Canonical host: Atoms. Owns no canonical state of its own.'

    hierarchical_nav = optionalContainer 'Hierarchical Navigation' 'Multi-axis labeled tree indexes over atoms (by-classification, by-tree, by-team, by-lifecycle, by-tag). Optional.'
    blast_radius = optionalContainer 'Blast Radius' 'Impact analysis for transitions. Read-only pipeline over the three cascade channels (predicate-kind, scope-premise, derivation invalidation). Owns blast reports + traversal indexes. Optional.'
    quality = optionalContainer 'Quality' 'Benchmarks, golden sets, faithfulness eval, LLM-as-judge, conflict-pipeline test runner, telemetry, failed-query archive. Optional.'

    llm_gateway = crossCutting 'LLM Gateway' 'Cross-cutting infrastructure (non-optional). Use-case-keyed model access. Implementer picks the tool; deployer configures models.'
  }

  agent -> aala.orchestration 'ingest / read / propose / approve' 'MCP / HTTP / CLI'

  aala.orchestration -> aala.ingestion 'accept(fragment)'
  aala.orchestration -> aala.atoms 'propose / read / update_status'
  aala.orchestration -> aala.projection 'read prose + navigable index'
  aala.orchestration -> aala.blast_radius 'analyze / record_resolution (if wired)'
  aala.orchestration -> storage 'snapshot ops'

  aala.ingestion -> aala.atoms 'normalized fragment for extraction'
  aala.ingestion -> storage 'append raw fragment'
  aala.ingestion -> aala.llm_gateway 'relevance filter (if LLM-based)'

  aala.atoms -> aala.llm_gateway 'extraction + conflict judge + classification/predicate suggest'
  aala.atoms -> storage 'write atoms to current snapshot'

  aala.hierarchical_nav -> aala.atoms 'changes_since(ref) — consume delta stream'
  aala.hierarchical_nav -> aala.llm_gateway 'label synthesis'
  aala.hierarchical_nav -> storage 'persist tree indexes (impl-choice)'

  aala.atoms -> aala.projection 'renders own claims via facet'
  aala.projection -> aala.llm_gateway 'narrative render'
  aala.projection -> storage 'write prose to current snapshot'

  aala.blast_radius -> aala.atoms 'traverse_relations + Scope.constraint_atoms + derivation reverse-index + update_status'
  aala.blast_radius -> aala.llm_gateway 'implicit pass'
  aala.blast_radius -> storage 'persist blast reports in snapshot'

  aala.quality -> aala.atoms 'read for retrieval eval; planted conflict cases via propose'
  aala.quality -> aala.projection 'check rendered output'
  aala.quality -> aala.llm_gateway 'LLM-as-judge'

  aala.llm_gateway -> llm 'chat / embed (use_case_keyed)' 'HTTPS'
}

views {
  view containersView of aala {
    title 'L2 — aala Containers'
    include *

    autoLayout TopBottom
  }
}
